{
  "name": "imobile",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "start": "react-native start",
    "test": "jest",
    "pods": "cd ios && pod install && cd ..",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "xCode": "cd ios && xed . && cd .."
  },
  "dependencies": {
    "@notifee/react-native": "^1.1.1",
    "@react-native-clipboard/clipboard": "^1.7.0",
    "@react-native-community/async-storage": "^1.11.0",
    "@react-native-community/checkbox": "^0.5.8",
    "@react-native-community/datetimepicker": "^3.2.0",
    "@react-native-firebase/app": "^10.8.1",
    "@react-native-firebase/messaging": "^10.8.1",
    "axios": "^0.19.2",
    "moment": "^2.26.0",
    "prop-types": "^15.7.2",
    "react": "16.13.1",
    "react-i18nify": "^3.1.6",
    "react-native": "0.63.4",
    "react-native-camera": "git+https://git@github.com/react-native-community/react-native-camera.git",
    "react-native-contacts": "^5.2.3",
    "react-native-device-info": "^8.1.3",
    "react-native-extended-stylesheet": "^0.12.0",
    "react-native-gesture-handler": "^1.10.3",
    "react-native-gesture-password": "^0.4.0",
    "react-native-image-resizer": "^1.2.3",
    "react-native-image-zoom-viewer": "^3.0.1",
    "react-native-masked-text": "^1.13.0",
    "react-native-modal-datetime-picker": "^9.2.0",
    "react-native-orientation-locker": "^1.3.1",
    "react-native-reanimated": "^1.9.0",
    "react-native-router-flux": "^4.2.0",
    "react-native-screens": "^2.8.0",
    "react-native-share": "^3.3.3",
    "react-native-signature-capture": "^0.4.10",
    "react-native-simple-radio-button": "^2.7.4",
    "react-native-vector-icons": "^8.0.0",
    "react-redux": "^7.2.0",
    "redux": "^4.0.5",
    "redux-thunk": "^2.3.0",
    "rn-fetch-blob": "^0.12.0"
  },
  "devDependencies": {
    "@babel/core": "^7.10.3",
    "@babel/runtime": "^7.10.3",
    "babel-eslint": "^10.1.0",
    "babel-jest": "^26.1.0",
    "babel-plugin-module-resolver": "^4.1.0",
    "eslint": "^7.20.0",
    "eslint-config-airbnb": "^18.2.1",
    "eslint-config-prettier": "^8.0.0",
    "eslint-plugin-import": "^2.22.1",
    "eslint-plugin-jsx-a11y": "^6.4.1",
    "eslint-plugin-prettier": "^3.3.1",
    "eslint-plugin-react": "^7.22.0",
    "eslint-plugin-react-hooks": "^4.2.0",
    "jest": "^26.1.0",
    "metro-react-native-babel-preset": "^0.59.0",
    "prettier": "^2.2.1",
    "react-test-renderer": "16.11.0"
  },
  "jest": {
    "preset": "react-native"
  }
}
